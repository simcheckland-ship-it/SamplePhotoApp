# Stage 1: Build the React application
FROM node:20-alpine AS build
WORKDIR /workspace

# Copy package configurations using the parent context path
COPY react-app/package*.json ./
RUN npm ci

# Copy the entire frontend source code and compile it
COPY react-app/ ./
RUN npm run build

# Stage 2: Serve the compiled static assets with Nginx
FROM nginx:alpine
COPY --from=build /workspace/build /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
